if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js').catch(() => {});
  });
}

/* Init defaults */
updateUnitLabels();
applySeriesToggle('x', true);
applySeriesToggle('y', true);
applySeriesToggle('z', true);
applySeriesToggle('t', true);
resetState();